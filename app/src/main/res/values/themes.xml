<resources xmlns:tools="http://schemas.android.com/tools">
    
    <style name="Theme.BlackBox" parent="Theme.MaterialComponents.Light.NoActionBar">
        
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <item name="colorSecondary">@color/primary_light</item>
        <item name="colorSecondaryVariant">@color/primary</item>
        <item name="colorOnSecondary">@color/white</item>
        
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
        

        <item name="actionMenuTextColor">@color/primary_text</item>

        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
    </style>

    <style name="ToolBarColorStyle" parent="ThemeOverlay.AppCompat.ActionBar">
        <item name="actionMenuTextColor">@color/white</item>
        <item name="colorControlNormal">@color/white</item>

        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
    </style>

    <style name="WelcomeTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@drawable/splash</item>
    </style>


    <style name="PhantomDialogStyle" parent="Theme.MaterialComponents.Dialog">
        <item name="colorPrimary">#6C3FC7</item>
        <item name="android:background">#1A1628</item>
        <item name="android:textColorPrimary">#C4A8FF</item>
        <item name="android:textColorSecondary">#7A5AB0</item>
    </style>

    <style name="PhantomButtonStyle" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">#6C3FC7</item>
    </style>

</resources>